# Copy this file to .env before running docker compose up.
# .env is git-ignored — never commit real secrets.

# ── Keycloak ──────────────────────────────────────────────────────────────
# Admin console credentials (only used at first startup)
KEYCLOAK_ADMIN_PASSWORD=admin

# ── Pomerium ──────────────────────────────────────────────────────────────
# Both secrets must be base64-encoded 32-byte random values.
# Generate with:  openssl rand -base64 32
POMERIUM_SHARED_SECRET=REPLACE_WITH_GENERATED_SECRET
POMERIUM_COOKIE_SECRET=REPLACE_WITH_GENERATED_SECRET

# Must match the client secret in keycloak/realm-export.json.
# For this demo, realm-export.json ships with the value below.
# In a real deployment, generate a random secret and update both places.
POMERIUM_IDP_CLIENT_SECRET=pomerium-demo-secret
